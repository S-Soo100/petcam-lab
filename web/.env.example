# petcam web — 환경변수 예시. 실제 값은 .env.local (gitignore) 에.

# ─────────────────────────────────────────────────────────────
# 서버 전용 (RLS 우회 service_role) — 기존 /web 라우트(/upload /queue ...)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Gemini 2.5 Flash — F3 추론
GEMINI_API_KEY=replace-with-gemini-key

# 로컬 영상 저장 경로 (Round 1 잔재 — Round 2 부터 R2)
POC_CLIPS_DIR=/path/to/poc-clips

# Round 1 PoC 식별자
DEV_USER_ID=replace-with-uuid
DEV_PET_ID=replace-with-uuid
ROUND1_CAMERA_ID=replace-with-uuid

# ─────────────────────────────────────────────────────────────
# 클라이언트 (브라우저) — /labeling 라벨링 웹 (NEXT_PUBLIC_ prefix 필수)
# ─────────────────────────────────────────────────────────────
# Supabase 익명 키 — RLS 가 책임지므로 노출 OK.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# 백엔드 FastAPI URL (label API 호출 + 영상 URL JSON).
# 로컬: http://localhost:8000
# prod: https://backend.tera-ai.uk (예시)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
