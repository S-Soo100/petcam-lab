# 테스트 스크립트 프레임 저장 경로 (scripts/test_rtsp.py 전용)
TEST_SNAPSHOT_PATH=storage/test_snapshot.jpg

# 캡처 워커 공용 설정 (backend/capture.py)
# SEGMENT_SECONDS: 한 mp4 파일에 담을 길이 (초). MVP는 60초 권장.
# CLIPS_DIR: 세그먼트 mp4가 쌓일 루트. 실제 파일은 {CLIPS_DIR}/{YYYY-MM-DD}/{camera_uuid}/{HHMMSS}_{motion|idle}.mp4
#
# Stage D3 부터 RTSP_URL / CAMERA_ID 는 더 이상 env 에 두지 않음.
# 카메라는 `POST /cameras` 로 등록하고 `cameras` 테이블이 원천.
SEGMENT_SECONDS=60
CLIPS_DIR=storage/clips
# ENCODED_DIR: ffmpeg 인코딩 산출물 폴더 (R2 업로드 source). 디스크 사용량은 원본의 ~1/3.
ENCODED_DIR=storage/encoded

# 움직임 감지 설정 (Stage B, backend/motion.py)
# MOTION_PIXEL_THRESHOLD: 두 프레임 간 픽셀 밝기 차이 임계 (0~255). 이 값 넘어야 "변한 픽셀" 로 카운트.
# MOTION_PIXEL_RATIO: 전체 픽셀 중 변한 비율(%). 이 값 이상이면 해당 프레임을 motion 으로 본다.
#   도마뱀 화면 5~10% 차지 + 야행성 IR 노이즈 대응 → 초기값 1.0. 오탐 많으면 올리고, 놓침 많으면 낮추기.
# MOTION_MIN_DURATION_FRAMES: N프레임 연속 motion 이어야 진짜 움직임으로 인정 (노이즈 필터).
#   12 프레임 ≈ 1초 (12fps 기준).
# MOTION_SEGMENT_THRESHOLD_SEC: 1분 세그먼트 안에 유효 motion 이 이 초 이상이면 파일명을 _motion.mp4 로 저장.
#   미만이면 _idle.mp4. 도마뱀 특성상 3초가 "유의미한 움직임" 최소 단위.
MOTION_PIXEL_THRESHOLD=25
MOTION_PIXEL_RATIO=1.0
MOTION_MIN_DURATION_FRAMES=12
MOTION_SEGMENT_THRESHOLD_SEC=3.0

# Supabase (Stage C+)
# - SUPABASE_URL: 대시보드 > Settings > API > Project URL
# - SUPABASE_SERVICE_ROLE_KEY: 같은 페이지 > service_role (secret) key. **절대 커밋 금지**.
#   RLS 바이패스 권한이라 클라이언트 코드에 노출되면 전체 DB 권한 유출.
# - DEV_USER_ID: Stage C 로컬 테스트용 하드코딩 user_id (auth.users.id). Stage D 에서 JWT 로 교체.
# - DEV_PET_ID: 선택. 해당 유저의 pets.id. 빈 값이면 camera_clips.pet_id = NULL 로 저장.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DEV_USER_ID=00000000-0000-0000-0000-000000000000
DEV_PET_ID=

# 인증 모드 (Stage D1+, Stage D5 에서 prod 전환)
# - dev: JWT 검증 스킵, DEV_USER_ID 그대로 사용. 로컬 개발·pytest 전용.
# - prod: Authorization: Bearer <JWT> 필수. Supabase access_token 을 검증.
#   외부망 공개(Cloudflare Tunnel) 할 때는 prod 필수. dev 로 두면 DEV_USER_ID 로 누구나 통과.
AUTH_MODE=dev

# Supabase JWT 검증 (AUTH_MODE=prod 일 때 필수)
# - SUPABASE_JWT_ISSUER: 일반적으로 {SUPABASE_URL}/auth/v1. 발급자 검증용.
# - SUPABASE_JWKS_URL: 공개키 셋 엔드포인트. {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# 카메라 비밀번호 암호화 키 (Stage D1+)
# - Fernet 대칭키 (32바이트 base64). 최초 1회 생성 후 절대 변경 금지 (변경 시 기존 DB 암호문 전부 복호화 불가).
# - 생성: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# - .env 에만 기입. 커밋 절대 금지. 맥북 분실 시 모든 카메라 RTSP 비번 노출 → 카메라 앱 계정 비번 전체 로테이션 필요.
CAMERA_SECRET_KEY=placeholder-replace-with-generated-fernet-key

# Cloudflare R2 (feature-r2-storage-encoding-labeling)
# 영상 클립과 썸네일을 인코딩 후 R2 에 업로드. 라벨링 웹이 signed URL 로 직접 GET.
# - R2_ACCOUNT_ID: 대시보드 우측 상단 "Account ID" (32자 hex). endpoint URL 조립용 + 디버깅용.
# - R2_ENDPOINT: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com (account_id 그대로 박힌 URL)
# - R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY: R2 > Manage R2 API Tokens 에서 토큰 생성 (Object Read & Write 권한)
# - R2_BUCKET: 버킷 이름 (예: petcam-clips). 대시보드 R2 > Buckets 에서 미리 생성.
# .env 에만 기입. 커밋 절대 금지.
R2_ACCOUNT_ID=your-account-id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-r2-bucket
