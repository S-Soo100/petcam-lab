# RTSP 카메라 소스
# Tapo C200 예시: rtsp://<user>:<pass>@<IP>:554/stream1
# - stream1: 1080p 고화질
# - stream2: 720p 저화질 (최신 Tapo 펌웨어 기준, 과거 스펙의 360p에서 변경)
# 스마트폰 IP Webcam 예시: rtsp://<IP>:8080/h264_pcm.sdp
RTSP_URL=rtsp://admin:password@192.168.0.10:554/stream1

# 테스트 스크립트 프레임 저장 경로
TEST_SNAPSHOT_PATH=storage/test_snapshot.jpg

# 캡처 워커 설정 (backend/capture.py)
# CAMERA_ID: /streams/{camera_id}/status 경로에 들어가는 식별자
# SEGMENT_SECONDS: 한 mp4 파일에 담을 길이 (초). MVP는 60초 권장.
# CLIPS_DIR: 세그먼트 mp4가 쌓일 루트. 실제 파일은 {CLIPS_DIR}/{YYYY-MM-DD}/{CAMERA_ID}/{HHMMSS}.mp4
CAMERA_ID=cam-1
SEGMENT_SECONDS=60
CLIPS_DIR=storage/clips
